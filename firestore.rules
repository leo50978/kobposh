rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function bootstrapFinanceEmail() {
      return get(/databases/$(database)/documents/settings/dpayment_admin_bootstrap).data.email;
    }

    function isFinanceAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.financeAdmin == true
          || (
            request.auth.token.email != null
            && (
              request.auth.token.email == "leovitch2004@gmail.com"
              || request.auth.token.email == bootstrapFinanceEmail()
            )
          )
        );
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && roomDoc(roomId).data != null
        && roomDoc(roomId).data.playerUids is list
        && request.auth.uid in roomDoc(roomId).data.playerUids;
    }

    function duelRoomDoc(roomId) {
      return get(/databases/$(database)/documents/duelRooms/$(roomId));
    }

    function isDuelRoomParticipant(roomId) {
      return signedIn()
        && duelRoomDoc(roomId).data != null
        && duelRoomDoc(roomId).data.playerUids is list
        && request.auth.uid in duelRoomDoc(roomId).data.playerUids;
    }

    function morpionRoomDoc(roomId) {
      return get(/databases/$(database)/documents/morpionRooms/$(roomId));
    }

    function isMorpionRoomParticipant(roomId) {
      return signedIn()
        && morpionRoomDoc(roomId).data != null
        && morpionRoomDoc(roomId).data.playerUids is list
        && request.auth.uid in morpionRoomDoc(roomId).data.playerUids;
    }

    function dameRoomDoc(roomId) {
      return get(/databases/$(database)/documents/dameRooms/$(roomId));
    }

    function isDameRoomParticipant(roomId) {
      return signedIn()
        && dameRoomDoc(roomId).data != null
        && dameRoomDoc(roomId).data.playerUids is list
        && request.auth.uid in dameRoomDoc(roomId).data.playerUids;
    }

    function isPublicWaitingDameRoom(roomId) {
      return signedIn()
        && dameRoomDoc(roomId).data != null
        && dameRoomDoc(roomId).data.status == "waiting"
        && dameRoomDoc(roomId).data.isPrivate == false;
    }

    function isSafeClientPresenceCreate(uid) {
      return isOwner(uid)
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "lastSeenAt",
          "lastSeenAtMs",
          "updatedAt",
          "sitePresencePage",
          "sitePresenceExpiresAtMs",
          "morpionLastInterestAtMs",
        ])
        && request.resource.data.uid == uid;
    }

    function isSafeClientPresenceUpdate(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "email",
          "lastSeenAt",
          "lastSeenAtMs",
          "updatedAt",
          "sitePresencePage",
          "sitePresenceExpiresAtMs",
          "morpionLastInterestAtMs",
        ])
        && request.resource.data.uid == resource.data.uid;
    }

    function canCreateDpaymentBootstrap() {
      return signedIn()
        && !exists(/databases/$(database)/documents/settings/dpayment_admin_bootstrap)
        && request.auth.token.email != null
        && request.auth.token.email == "leovitch2004@gmail.com"
        && request.resource.data.keys().hasOnly([
          "email",
          "createdByUid",
          "createdAt",
          "updatedAt",
          "locked",
          "mode",
        ])
        && request.resource.data.email == "leovitch2004@gmail.com"
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.locked == true
        && request.resource.data.mode == "email_password";
    }

    match /clients/{uid} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow create: if isFinanceAdmin() || isSafeClientPresenceCreate(uid);
      allow update: if isFinanceAdmin() || isSafeClientPresenceUpdate(uid);
      allow delete: if isFinanceAdmin();
    }

    match /championnats/mopyon_current {
      allow read: if true;
      allow write: if isFinanceAdmin();
    }

    match /clients/{uid}/orders/{orderId} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow write: if isFinanceAdmin();
    }

    match /{path=**}/orders/{orderId} {
      allow read: if isFinanceAdmin();
      allow write: if false;
    }

    match /clients/{uid}/withdrawals/{withdrawalId} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow write: if isFinanceAdmin();
    }

    match /{path=**}/withdrawals/{withdrawalId} {
      allow read: if isFinanceAdmin();
      allow write: if false;
    }

    match /clients/{uid}/xchanges/{entryId} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow write: if isFinanceAdmin();
    }

    match /clients/{uid}/transfers/{transferId} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow write: if isFinanceAdmin();
    }

    match /clients/{uid}/referrals/{referralId} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow write: if isFinanceAdmin();
    }

    match /clients/{uid}/referralRewards/{rewardId} {
      allow read: if isOwner(uid) || isFinanceAdmin();
      allow write: if isFinanceAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isFinanceAdmin()
        || (signedIn()
          && resource.data.playerUids is list
          && request.auth.uid in resource.data.playerUids);
      allow write: if false;

      match /actions/{actionId} {
        allow read: if isFinanceAdmin() || isRoomParticipant(roomId);
        allow write: if false;
      }

      match /settlements/{uid} {
        allow read: if isFinanceAdmin() || isOwner(uid);
        allow write: if false;
      }
    }

    match /gameStates/{roomId} {
      allow read, write: if false;
    }

    match /duelRooms/{roomId} {
      allow read: if isFinanceAdmin()
        || (signedIn()
          && resource.data.playerUids is list
          && request.auth.uid in resource.data.playerUids);
      allow write: if false;

      match /actions/{actionId} {
        allow read: if isFinanceAdmin() || isDuelRoomParticipant(roomId);
        allow write: if false;
      }

      match /settlements/{uid} {
        allow read: if isFinanceAdmin() || isOwner(uid);
        allow write: if false;
      }
    }

    match /duelGameStates/{roomId} {
      allow read, write: if false;
    }

    match /morpionRooms/{roomId} {
      allow read: if isFinanceAdmin()
        || (signedIn()
          && resource.data.playerUids is list
          && request.auth.uid in resource.data.playerUids);
      allow write: if false;

      match /actions/{actionId} {
        allow read: if isFinanceAdmin() || isMorpionRoomParticipant(roomId);
        allow write: if false;
      }

      match /settlements/{uid} {
        allow read: if isFinanceAdmin() || isOwner(uid);
        allow write: if false;
      }
    }

    match /morpionGameStates/{roomId} {
      allow read: if isFinanceAdmin() || isMorpionRoomParticipant(roomId);
      allow write: if false;
    }

    match /dameRooms/{roomId} {
      allow read: if isFinanceAdmin()
        || (signedIn()
          && resource.data.playerUids is list
          && request.auth.uid in resource.data.playerUids)
        || isPublicWaitingDameRoom(roomId);
      allow write: if false;

      match /actions/{actionId} {
        allow read: if isFinanceAdmin() || isDameRoomParticipant(roomId) || isPublicWaitingDameRoom(roomId);
        allow write: if false;
      }

      match /settlements/{uid} {
        allow read: if isFinanceAdmin() || isOwner(uid);
        allow write: if false;
      }
    }

    match /dameGameStates/{roomId} {
      allow read: if isFinanceAdmin() || isDameRoomParticipant(roomId) || isPublicWaitingDameRoom(roomId);
      allow write: if false;
    }

    match /paymentMethods/{docId} {
      allow read, write: if isFinanceAdmin();
    }

    match /settings/dpayment_admin_bootstrap {
      allow read: if false;
      allow create: if canCreateDpaymentBootstrap();
      allow update, delete: if isFinanceAdmin();
    }

    match /settings/home_hero_slides_v1 {
      allow read: if true;
      allow write: if isFinanceAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isFinanceAdmin();
    }

    match /pdfConfig/{docId} {
      allow read, write: if isFinanceAdmin();
    }

    match /dashboardPushSubscriptions/{subscriptionId} {
      allow read: if isFinanceAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if isFinanceAdmin()
        || (
          signedIn()
          && request.resource.data.uid == request.auth.uid
        );
      allow update: if isFinanceAdmin()
        || (
          signedIn()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
        );
      allow delete: if isFinanceAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /ambassadors/{ambassadorId} {
      allow read: if isFinanceAdmin();
      allow write: if isFinanceAdmin();

      match /private/{docId} {
        allow read, write: if isFinanceAdmin();
      }

      match /referrals/{referralId} {
        allow read: if isFinanceAdmin();
        allow write: if isFinanceAdmin();
      }
    }

    match /ambassadorGameEvents/{eventId} {
      allow read, write: if isFinanceAdmin();
    }

    match /globalChannelMessages/{messageId} {
      allow read: if true;
      allow write: if isFinanceAdmin();
    }

    match /supportThreads/{threadId} {
      allow read: if isFinanceAdmin()
        || (signedIn() && threadId == ("user_" + request.auth.uid));
      allow write: if isFinanceAdmin();

      match /messages/{messageId} {
        allow read, write: if isFinanceAdmin();
      }
    }
  }
}
